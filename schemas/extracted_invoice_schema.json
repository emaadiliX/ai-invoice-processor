{
  "type": "object",
  "required": [
    "invoice_id",
    "invoice_date",
    "vendor_name",
    "po_reference",
    "currency",
    "line_items",
    "subtotal",
    "total_amount",
    "confidence_scores",
    "bounding_boxes"
  ],
  "properties": {
    "invoice_id": { "type": "string" },
    "invoice_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "due_date": { "type": ["string", "null"] },
    "vendor_name": { "type": "string" },
    "vendor_id": { "type": ["string", "null"] },
    "po_reference": { "type": ["string", "null"] },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },

    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["line_id", "description", "quantity", "unit_price", "total"],
        "properties": {
          "line_id": { "type": "integer" },
          "description": { "type": "string" },
          "quantity": { "type": "number" },
          "unit_price": { "type": "number" },
          "total": { "type": "number" }
        }
      }
    },

    "subtotal": { "type": "number" },
    "tax_amount": { "type": ["number", "null"] },
    "total_amount": { "type": ["number", "null"] },

    "confidence_scores": { "type": "object" },
    "low_confidence_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extraction_notes": { "type": "string" },
    "bounding_boxes": { "type": "object" }
  }
}
